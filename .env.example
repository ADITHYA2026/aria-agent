# ============================================
# ARIA Agent - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ============================================
# REQUIRED API KEYS
# ============================================

# Google Gemini API Key
# Get it from: https://aistudio.google.com/
# Free tier: 60 requests per minute
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API Key  
# Get it from: https://tavily.com/
# Free tier: 1000 searches/month
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Redis URL for session persistence (optional)
# Default: redis://localhost:6379
# Set empty string to disable Redis
REDIS_URL=redis://localhost:6379

# Model Configuration
# Options: gemini-2.5-flash, gemini-1.5-flash, gemini-1.5-pro
MODEL=gemini-2.5-flash

# Maximum iterations per task
MAX_ITERATIONS=12

# CORS Origins (comma-separated for multiple)
# Default: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# NOTES
# ============================================
# 1. Never commit .env file to GitHub
# 2. Keep your API keys secure
# 3. Use .env.example as template for new installations